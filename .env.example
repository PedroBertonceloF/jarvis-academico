# Configuração recomendada para a entrega final.
# A chave real deve ficar somente no .env local ou nos Secrets do Hugging Face.
# LLM_MODE=gemma continua válido por compatibilidade com o projeto.
# Observação: as variáveis GEMMA_* são nomes legados; elas configuram
# o cliente LLM remoto OpenAI-compatible, atualmente usando Qwen.

LLM_MODE=gemma
GEMMA_BASE_URL=https://llm.liaufms.org/v1/qwen2-5-14b-instruct-awq
GEMMA_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
GEMMA_API_KEY=COLE_A_CHAVE_AQUI
GEMMA_TIMEOUT_SECONDS=180
GEMMA_MAX_TOKENS=512

# Recuperação de documentos.
# Use hibrido na entrega. Em máquinas com pouca memória, lexical pode ser usado como fallback.
RAG_MODE=hibrido
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

PYTHONUNBUFFERED=1
