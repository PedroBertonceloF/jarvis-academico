# Modo de desenvolvimento sem consumir tokens do LIA.
LLM_MODE=mock

# Para homologação/vídeo, troque LLM_MODE para gemma e preencha a chave fornecida pelo professor.
GEMMA_BASE_URL=https://llm.liaufms.org/v1/gemma-3-12b-it
GEMMA_API_KEY=COLE_A_CHAVE_AQUI
GEMMA_MODEL=google/gemma-3-12b-it

# Modelo de embeddings local usado no RAG.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
